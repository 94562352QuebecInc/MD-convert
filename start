#!/bin/bash
# start — Launch the MD Converter web app on port 4000

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PID_FILE="$SCRIPT_DIR/.app.pid"

if [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
  echo "⚠️  App is already running (PID $(cat "$PID_FILE"))."
  echo "   Open: http://localhost:4000"
  exit 0
fi

echo "🚀 Starting MD Converter…"
cd "$SCRIPT_DIR"
nohup python3 app.py > "$SCRIPT_DIR/app.log" 2>&1 &
echo $! > "$PID_FILE"
sleep 1.5

if kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
  echo "✅ Running on http://localhost:4000  (PID $(cat "$PID_FILE"))"
  echo "   Logs: $SCRIPT_DIR/app.log"
else
  echo "❌ App failed to start. Check app.log for details."
  rm -f "$PID_FILE"
  exit 1
fi
